{
  "manifest_version": 3,
  "name": "LinkedIn Home Blocker",
  "version": "1.0",
  "description": "Hides the Home button in LinkedIn's navigation bar.",
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
